{
  "name": "weblens",
  "version": "2.0.0",
  "description": "Premium Web Intelligence API with x402 micropayments — web scraping, screenshots, data extraction, AI research for autonomous agents",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-scraping",
    "x402",
    "micropayments",
    "ai-agent",
    "web-intelligence",
    "data-extraction",
    "cloudflare-workers",
    "usdc",
    "hono"
  ],
  "homepage": "https://api.weblens.dev",
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "lint": "eslint src scripts --ext .ts",
    "lint:fix": "eslint src scripts --ext .ts --fix",
    "verify-bazaar": "npx tsx scripts/verify-bazaar.ts",
    "bootstrap-payment": "npx tsx scripts/bootstrap-payment.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@coinbase/x402": "^2.1.0",
    "@hono/eslint-config": "^2.1.0",
    "@scalar/hono-api-reference": "^0.10.11",
    "@types/node": "^25.6.0",
    "@x402/axios": "^2.11.0",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/extensions": "^2.11.0",
    "@x402/hono": "^2.11.0",
    "hono": "^4.12.15",
    "typescript-eslint": "^8.59.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@coinbase/x402",
      "@opensea/seaport-js",
      "bigint-buffer",
      "bufferutil",
      "esbuild",
      "keccak",
      "opensea-js",
      "secp256k1",
      "sharp",
      "unrs-resolver",
      "utf-8-validate",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@coinbase/agentkit": "^0.10.4",
    "axios": "^1.15.2",
    "eslint": "10.2.1",
    "fast-check": "^4.7.0",
    "typescript": "^6.0.3",
    "viem": "^2.48.4",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}